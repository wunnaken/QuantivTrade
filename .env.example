# Optional: get a free API key at https://finnhub.io to show live S&P 500, Oil (USO), and Gold (GLD) in the top ticker bar.
# Bitcoin uses CoinGecko (no key required).
# FINNHUB_API_KEY=your_key_here

# Optional: Alpha Vantage for additional market data (https://www.alphavantage.co/support/#api-key).
# ALPHA_VANTAGE_API_KEY=your_key_here

# For Macro Radar map: country headlines, elections, and political news.
# Get a free key at https://newsapi.org (free tier: 100 requests/day; "everything" has ~24h delay).
# NEWS_API_KEY=your_key_here
# Optional: comma-separated source IDs for election/political search (e.g. reuters,associated-press,bbc-news).
# NEWS_SOURCES=reuters,associated-press,bbc-news

# Optional: one account that gets a unique badge only they can have (others see it on their profile/posts).
# Set to the account's email (e.g. founder or admin). Leave unset to disable.
# NEXT_PUBLIC_SPECIAL_ACCOUNT_EMAIL=founder@example.com

# Smart Search: AI analysis on ticker pages (Claude). Get a key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_key_here

# Feedback form: sends to zack.mutz01@gmail.com. Get a key at https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Supabase: database and auth (https://supabase.com/dashboard → Project Settings → API)
# Use these to replace hardcoded data (users, posts, watchlist, follow state, etc.).
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Optional: service role key for server-only admin operations (never expose to client).
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
